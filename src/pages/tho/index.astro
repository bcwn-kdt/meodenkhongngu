---
import "../../styles/global.css";
import { getCollection } from "astro:content";

const poems = await getCollection("poems");
const sorted = poems
  .filter((poem) => poem.data.published)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thơ | Mèo Đen Không Ngủ</title>
  </head>

  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="logo" href="/">Mèo Đen Không Ngủ</a>

        <nav class="nav">
          <a href="/tho">Thơ</a>
          <a href="/tap-tho/va-vao-lan-yeu-cuoi">Va Vào Lần Yêu Cuối</a>
          <a href="/ve-meo">Về Mèo</a>
          <a href="/admin">Admin</a>
        </nav>
      </header>

      <main>
        <section class="archive">
          <p class="eyebrow">archive</p>
          <h1 class="page-title">Thơ</h1>

          <p class="intro">
            Những bài thơ đã từng là một vết thương, một lời tạm biệt,
            hoặc một cách để sống sót qua đêm.
          </p>

          <div class="poem-list">
            {
              sorted.map((poem) => (
                <a class="poem-item" href={`/tho/${poem.id.replace(/\.md$/, "")}`}>
                  <span>{poem.data.date.toLocaleDateString("vi-VN")}</span>
                  <h2>{poem.data.title}</h2>
                  {poem.data.excerpt && <p>{poem.data.excerpt}</p>}
                </a>
              ))
            }
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <p>© Mèo Đen Không Ngủ</p>
      </footer>
    </div>
  </body>
</html>