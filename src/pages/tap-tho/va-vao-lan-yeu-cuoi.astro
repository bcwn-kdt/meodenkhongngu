---
import "../../styles/global.css";
import FlipBook from "../../components/Flipbook.jsx";
import { getCollection } from "astro:content";
import { marked } from "marked";

const entries = await getCollection("poems");

const sorted = entries
  .filter((entry) => {
    return (
      entry.data.published &&
      entry.data.showInBook &&
      entry.data.collection === "Va Vào Lần Yêu Cuối"
    );
  })
  .sort((a, b) => {
    return (a.data.order || 999) - (b.data.order || 999);
  });

const poems = sorted.map((entry) => ({
  slug: entry.slug,
  title: entry.data.title,
  date: entry.data.date.toLocaleDateString("vi-VN"),
  excerpt: entry.data.excerpt,
  html: marked.parse(entry.body),
}));
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Va Vào Lần Yêu Cuối | Mèo Đen Không Ngủ</title>
  </head>

  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="logo" href="/">Mèo Đen Không Ngủ</a>

        <nav class="nav">
          <a href="/tho">Thơ</a>
          <a href="/tap-tho/va-vao-lan-yeu-cuoi">Va Vào Lần Yêu Cuối</a>
          <a href="/ve-meo">Về Mèo</a>
        </nav>
      </header>
    </div>

    <FlipBook client:only="react" poems={poems} />

    <style is:global>
      .book-section {
        padding: 72px 20px 20px;
      }

      .book-top {
        max-width: 720px;
        margin: 0 auto 42px;
        text-align: center;
      }

      .book-eyebrow {
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.22em;
        font-size: 12px;
      }

      .book-top h1 {
        font-family: Georgia, serif;
        font-size: clamp(48px, 8vw, 92px);
        line-height: 0.92;
        margin: 14px 0 20px;
      }

      .book-top p {
        color: var(--muted);
        font-size: 18px;
      }

      .book-wrap {
        min-height: 720px;
        display: grid;
        place-items: center;
        padding: 34px 0;
      }

      .flip-book {
        filter: drop-shadow(0 36px 90px rgba(0, 0, 0, 0.75));
      }

      .book-page {
        background:
          linear-gradient(90deg, rgba(0, 0, 0, 0.04), transparent 18%),
          #efe5d1;
        color: #17120f;
        border: 1px solid rgba(0, 0, 0, 0.16);
        padding: 46px;
        overflow: hidden;
        font-family: Georgia, serif;
      }

      .cover-page {
        background:
          linear-gradient(rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.82)),
          #120c0b;
        color: #f3e7d5;
        display: grid;
        place-items: center;
        text-align: center;
      }

      .cover-page h2 {
        font-family: Georgia, serif;
        font-size: 56px;
        line-height: 0.94;
        margin: 18px 0;
      }

      .cover-page p {
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 12px;
      }

      .intro-page {
        display: grid;
        align-content: center;
        font-size: 22px;
        line-height: 1.9;
      }

      .poem-book-page h2 {
        font-family: Georgia, serif;
        font-size: 36px;
        line-height: 1;
        margin: 12px 0 18px;
      }

      .book-date {
        color: rgba(0, 0, 0, 0.45);
        font-size: 12px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .book-excerpt {
        color: rgba(0, 0, 0, 0.58);
        font-style: italic;
        margin-bottom: 24px;
      }

      .book-poem-body {
        font-size: 16px;
        line-height: 1.85;
      }

      .book-poem-body p {
        margin: 0 0 18px;
      }

      .end-page {
        display: grid;
        place-items: center;
        text-align: center;
        font-family: Georgia, serif;
        font-size: 52px;
      }

      .mobile-note {
        text-align: center;
        color: var(--muted);
        font-size: 14px;
      }
    </style>
  </body>
</html>