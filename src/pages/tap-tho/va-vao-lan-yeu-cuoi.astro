---
import "../../styles/global.css";
import FlipBook from "../../components/Flipbook.jsx";
import { getCollection } from "astro:content";
import { marked } from "marked";

const entries = await getCollection("poems");

const sorted = entries
  .filter((entry) => {
    return (
      entry.data.published &&
      entry.data.showInBook &&
      entry.data.collection === "Va Vào Lần Yêu Cuối"
    );
  })
  .sort((a, b) => {
    return (a.data.order || 999) - (b.data.order || 999);
  });

const poems = sorted.map((entry) => ({
  slug: entry.slug,
  title: entry.data.title,
  date: entry.data.date.toLocaleDateString("vi-VN"),
  excerpt: entry.data.excerpt,
  html: marked.parse(entry.body),
}));
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Va Vào Lần Yêu Cuối | Mèo Đen Không Ngủ</title>
  </head>

  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="logo" href="/">Mèo Đen Không Ngủ</a>

        <nav class="nav">
          <a href="/tho">Thơ</a>
          <a href="/tap-tho/va-vao-lan-yeu-cuoi">Va Vào Lần Yêu Cuối</a>
          <a href="/ve-meo">Về Mèo</a>
        </nav>
      </header>
    </div>

    <FlipBook client:only="react" poems={poems} />

    <style is:global>
      .book-section {
        position: relative;
        padding: 72px 20px 26px;
        overflow: hidden;
      }

      .book-section::before {
        content: "";
        position: absolute;
        inset: 6% 0 auto;
        height: 520px;
        pointer-events: none;
        background:
          radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.16), transparent 34%),
          radial-gradient(circle at 22% 64%, rgba(201, 160, 109, 0.14), transparent 26%);
        opacity: 0.7;
        filter: blur(14px);
      }

      .book-top {
        position: relative;
        z-index: 1;
        max-width: 820px;
        margin: 0 auto 52px;
        text-align: center;
      }

      .book-top h1 {
        font-family: var(--font-serif);
        font-size: clamp(48px, 8vw, 96px);
        font-weight: 700;
        line-height: 1;
        letter-spacing: -0.06em;
        margin: 10px 0 22px;
        color: var(--text);
        text-wrap: balance;
      }

      .book-top p {
        color: var(--text-soft);
        font-family: var(--font-ui);
        font-size: clamp(16px, 2vw, 19px);
        line-height: 1.8;
        max-width: 720px;
        margin: 0 auto;
      }

      .book-wrap {
        position: relative;
        z-index: 1;
        min-height: 720px;
        display: grid;
        place-items: center;
        padding: 34px 0;
      }

      .flip-book {
        filter: drop-shadow(0 42px 110px rgba(0, 0, 0, 0.85));
      }

      .book-page {
        position: relative;
        background:
          radial-gradient(circle at top left, rgba(255, 255, 255, 0.48), transparent 28%),
          linear-gradient(90deg, rgba(0, 0, 0, 0.05), transparent 20%),
          repeating-linear-gradient(0deg, rgba(0, 0, 0, 0.018) 0 1px, transparent 1px 5px),
          #f0e5d1;
        color: var(--ink);
        border: 1px solid rgba(0, 0, 0, 0.18);
        padding: 44px;
        overflow: hidden;
        font-family: var(--font-serif);
        font-feature-settings: "kern";
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .book-page::after {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
          linear-gradient(90deg, rgba(0, 0, 0, 0.09), transparent 12%, transparent 88%, rgba(0, 0, 0, 0.08)),
          radial-gradient(circle at 50% 30%, transparent 0%, rgba(0, 0, 0, 0.04) 100%);
      }

      .cover-page {
        background:
          radial-gradient(circle at 50% 18%, rgba(255, 255, 255, 0.12), transparent 30%),
          linear-gradient(145deg, rgba(255, 255, 255, 0.08), transparent 34%),
          linear-gradient(180deg, #0a0a0c 0%, #020203 100%);
        color: #ffffff;
        display: grid;
        place-items: center;
        text-align: center;
        padding: 42px;
      }

      .cover-page::after {
        background:
          linear-gradient(90deg, rgba(255, 255, 255, 0.08), transparent 18%, transparent 82%, rgba(255, 255, 255, 0.06)),
          radial-gradient(circle at 50% 60%, transparent 0%, rgba(0, 0, 0, 0.54) 78%);
      }

      .cover-art {
        position: absolute;
        inset: 0;
        overflow: hidden;
        z-index: 0;
      }

      .cover-art::before {
        content: "";
        position: absolute;
        inset: 28px;
        border: 1px solid rgba(255, 255, 255, 0.16);
      }

      .cover-art::after {
        content: "";
        position: absolute;
        left: 50%;
        top: 57%;
        width: 220px;
        height: 220px;
        transform: translate(-50%, -50%);
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 999px;
        opacity: 0.55;
      }

      .moon {
        position: absolute;
        left: 50%;
        top: 28%;
        width: 118px;
        height: 118px;
        transform: translateX(-50%);
        border-radius: 999px;
        background:
          radial-gradient(circle at 36% 28%, #ffffff, rgba(255, 255, 255, 0.86) 32%, rgba(255, 255, 255, 0.12) 68%, transparent 70%);
        filter: blur(0.2px) drop-shadow(0 0 38px rgba(255, 255, 255, 0.38));
        opacity: 0.78;
      }

      .cat-silhouette {
        position: absolute;
        left: 50%;
        bottom: 142px;
        width: 92px;
        height: 70px;
        transform: translateX(-50%);
        border-radius: 48% 48% 36% 36%;
        background: rgba(0, 0, 0, 0.88);
        box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.04);
      }

      .cat-silhouette::before,
      .cat-silhouette::after {
        content: "";
        position: absolute;
        top: -20px;
        width: 0;
        height: 0;
        border-left: 18px solid transparent;
        border-right: 18px solid transparent;
        border-bottom: 34px solid rgba(0, 0, 0, 0.88);
      }

      .cat-silhouette::before {
        left: 10px;
        transform: rotate(-18deg);
      }

      .cat-silhouette::after {
        right: 10px;
        transform: rotate(18deg);
      }

      .cover-content {
        position: relative;
        z-index: 1;
        display: grid;
        place-items: center;
        min-height: 100%;
        padding: 40px 18px;
      }

      .cover-author {
        color: rgba(255, 255, 255, 0.72);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-family: var(--font-ui);
        font-size: 11px;
        font-weight: 700;
        margin: 0 0 auto;
      }

      .cover-page h2 {
        font-family: var(--font-serif);
        font-size: clamp(42px, 6vw, 60px);
        font-weight: 700;
        line-height: 0.98;
        letter-spacing: -0.06em;
        margin: auto 0 22px;
        text-wrap: balance;
      }

      .cover-page small {
        color: rgba(255, 255, 255, 0.72);
        font-family: var(--font-ui);
        font-size: 11px;
        letter-spacing: 0.08em;
        line-height: 1.7;
        text-transform: uppercase;
      }

      .intro-page {
        display: grid;
        align-content: center;
        font-family: var(--font-serif);
      }

      .intro-inner {
        position: relative;
        z-index: 1;
        max-width: 300px;
        margin: 0 auto;
      }

      .intro-inner span {
        display: block;
        color: rgba(0, 0, 0, 0.52);
        font-family: var(--font-ui);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        margin-bottom: 28px;
      }

      .intro-inner p {
        font-size: 21px;
        line-height: 1.9;
        margin: 0 0 22px;
      }

      .poem-book-page {
        display: grid;
        align-content: start;
      }

      .book-page-number {
        position: absolute;
        right: 34px;
        bottom: 28px;
        color: rgba(0, 0, 0, 0.35);
        font-family: var(--font-ui);
        font-size: 11px;
        letter-spacing: 0.16em;
      }

      .poem-book-page h2 {
        position: relative;
        z-index: 1;
        font-family: var(--font-serif);
        font-size: 30px;
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: -0.035em;
        margin: 12px 0 18px;
      }

      .book-date {
        position: relative;
        z-index: 1;
        color: rgba(0, 0, 0, 0.48);
        font-family: var(--font-ui);
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin: 0;
      }

      .book-excerpt {
        position: relative;
        z-index: 1;
        color: rgba(0, 0, 0, 0.62);
        font-family: var(--font-serif);
        font-size: 15px;
        font-style: italic;
        line-height: 1.75;
        margin-bottom: 24px;
      }

      .book-poem-body {
        position: relative;
        z-index: 1;
        font-family: var(--font-serif);
        font-size: 15px;
        line-height: 1.88;
      }

      .book-poem-body p {
        margin: 0 0 16px;
      }

      .end-page {
        display: grid;
        place-items: center;
        text-align: center;
        font-family: var(--font-serif);
        font-size: 52px;
        font-weight: 700;
      }

      .end-page div {
        position: relative;
        z-index: 1;
      }

      .end-page small {
        display: block;
        color: rgba(0, 0, 0, 0.56);
        font-family: var(--font-ui);
        font-size: 12px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .mobile-note {
        text-align: center;
        color: var(--muted);
        font-family: var(--font-ui);
        font-size: 14px;
      }

      @media (max-width: 760px) {
        .book-section {
          padding-inline: 12px;
        }

        .book-wrap {
          min-height: 620px;
          overflow-x: hidden;
        }

        .book-page {
          padding: 34px;
        }

        .poem-book-page h2 {
          font-size: 26px;
        }

        .book-poem-body {
          font-size: 14px;
          line-height: 1.82;
        }
      }
    </style>
  </body>
</html>
