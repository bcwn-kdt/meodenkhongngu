---
import "../../styles/global.css";
import FlipBook from "../../components/Flipbook.jsx";
import { getCollection } from "astro:content";
import { marked } from "marked";

const entries = await getCollection("poems");

const sorted = entries
  .filter((entry) => {
    return (
      entry.data.published &&
      entry.data.showInBook &&
      entry.data.collection === "Va Vào Lần Yêu Cuối"
    );
  })
  .sort((a, b) => {
    return (a.data.order || 999) - (b.data.order || 999);
  });

const poems = sorted.map((entry) => ({
  slug: entry.slug,
  title: entry.data.title,
  date: entry.data.date.toLocaleDateString("vi-VN"),
  excerpt: entry.data.excerpt,
  html: marked.parse(entry.body),
}));
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Va Vào Lần Yêu Cuối | Mèo Đen Không Ngủ</title>
  </head>

  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="logo" href="/">Mèo Đen Không Ngủ</a>

        <nav class="nav">
          <a href="/tho">Thơ</a>
          <a href="/tap-tho/va-vao-lan-yeu-cuoi">Va Vào Lần Yêu Cuối</a>
          <a href="/ve-meo">Về Mèo</a>
        </nav>
      </header>
    </div>

    <FlipBook client:only="react" poems={poems} />

    <style is:global>
      .book-section {
        padding: 72px 20px 20px;
      }

      .book-top {
        max-width: 760px;
        margin: 0 auto 42px;
        text-align: center;
      }

      .book-eyebrow {
        color: var(--text-soft);
        text-transform: uppercase;
        letter-spacing: 0.22em;
        font-family: var(--font-ui);
        font-size: 12px;
        font-weight: 700;
      }

      .book-top h1 {
        font-family: var(--font-serif);
        font-size: clamp(46px, 8vw, 90px);
        font-weight: 700;
        line-height: 1.02;
        letter-spacing: -0.055em;
        margin: 14px 0 20px;
        color: var(--text);
      }

      .book-top p {
        color: var(--text-soft);
        font-family: var(--font-ui);
        font-size: 18px;
        line-height: 1.75;
      }

      .book-wrap {
        min-height: 720px;
        display: grid;
        place-items: center;
        padding: 34px 0;
      }

      .flip-book {
        filter: drop-shadow(0 36px 90px rgba(0, 0, 0, 0.75));
      }

      .book-page {
        background:
          radial-gradient(circle at top left, rgba(255, 255, 255, 0.45), transparent 28%),
          linear-gradient(90deg, rgba(0, 0, 0, 0.045), transparent 18%),
          #f0e5d1;
        color: var(--ink);
        border: 1px solid rgba(0, 0, 0, 0.16);
        padding: 46px;
        overflow: hidden;
        font-family: var(--font-serif);
        font-feature-settings: "kern";
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .cover-page {
        background:
          radial-gradient(circle at top, rgba(255, 255, 255, 0.12), transparent 36%),
          linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.86)),
          #070707;
        color: #ffffff;
        display: grid;
        place-items: center;
        text-align: center;
      }

      .cover-page h2 {
        font-family: var(--font-serif);
        font-size: clamp(42px, 6vw, 58px);
        font-weight: 700;
        line-height: 1.02;
        letter-spacing: -0.055em;
        margin: 18px 0;
      }

      .cover-page p {
        color: rgba(255, 255, 255, 0.72);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-family: var(--font-ui);
        font-size: 12px;
        font-weight: 700;
      }

      .cover-page small {
        color: rgba(255, 255, 255, 0.72);
        font-family: var(--font-ui);
        line-height: 1.7;
      }

      .intro-page {
        display: grid;
        align-content: center;
        font-family: var(--font-serif);
        font-size: 22px;
        line-height: 1.9;
      }

      .poem-book-page h2 {
        font-family: var(--font-serif);
        font-size: 34px;
        font-weight: 700;
        line-height: 1.12;
        letter-spacing: -0.035em;
        margin: 12px 0 18px;
      }

      .book-date {
        color: rgba(0, 0, 0, 0.48);
        font-family: var(--font-ui);
        font-size: 12px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .book-excerpt {
        color: rgba(0, 0, 0, 0.62);
        font-family: var(--font-serif);
        font-style: italic;
        line-height: 1.75;
        margin-bottom: 24px;
      }

      .book-poem-body {
        font-family: var(--font-serif);
        font-size: 16px;
        line-height: 1.9;
      }

      .book-poem-body p {
        margin: 0 0 18px;
      }

      .end-page {
        display: grid;
        place-items: center;
        text-align: center;
        font-family: var(--font-serif);
        font-size: 52px;
        font-weight: 700;
      }

      .mobile-note {
        text-align: center;
        color: var(--muted);
        font-family: var(--font-ui);
        font-size: 14px;
      }
    </style>
  </body>
</html>
