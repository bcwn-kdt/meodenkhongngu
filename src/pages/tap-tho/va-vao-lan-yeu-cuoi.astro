---
import "../../styles/global.css";
import FlipBook from "../../components/Flipbook.jsx";
import { getCollection } from "astro:content";
import { marked } from "marked";

const entries = await getCollection("poems");

const sorted = entries
  .filter((entry) => {
    return (
      entry.data.published &&
      entry.data.showInBook &&
      entry.data.collection === "Va Vào Lần Yêu Cuối"
    );
  })
  .sort((a, b) => {
    return (a.data.order || 999) - (b.data.order || 999);
  });

const poems = sorted.map((entry) => ({
  slug: entry.slug,
  title: entry.data.title,
  excerpt: entry.data.excerpt,
  html: marked.parse(entry.body || ""),
}));
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Va Vào Lần Yêu Cuối | Mèo Đen Không Ngủ</title>
  </head>

  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="logo" href="/">Mèo Đen Không Ngủ</a>

        <nav class="nav">
          <a href="/tho">Thơ</a>
          <a href="/tap-tho/va-vao-lan-yeu-cuoi">Va Vào Lần Yêu Cuối</a>
          <a href="/ve-meo">Về Mèo</a>
        </nav>
      </header>
    </div>

    <FlipBook client:only="react" poems={poems} />

    <style is:global>
      .book-section { position: relative; padding: 72px 20px 26px; overflow: hidden; }
      .book-section::before { content: ""; position: absolute; inset: 6% 0 auto; height: 520px; pointer-events: none; background: radial-gradient(circle at 50% 0%, rgba(255,255,255,.16), transparent 34%), radial-gradient(circle at 22% 64%, rgba(201,160,109,.14), transparent 26%); opacity: .7; filter: blur(14px); }
      .book-top { position: relative; z-index: 1; max-width: 820px; margin: 0 auto 52px; text-align: center; }
      .book-top h1 { font-family: var(--font-serif); font-size: clamp(48px,8vw,96px); font-weight: 700; line-height: 1; letter-spacing: -.06em; margin: 10px 0 22px; color: var(--text); text-wrap: balance; }
      .book-top p { color: var(--text-soft); font-family: var(--font-ui); font-size: clamp(16px,2vw,19px); line-height: 1.8; max-width: 720px; margin: 0 auto; }
      .book-wrap { position: relative; z-index: 1; min-height: 720px; display: grid; place-items: center; padding: 34px 0; }
      .flip-book { filter: drop-shadow(0 42px 110px rgba(0,0,0,.85)); }
      .book-page { position: relative; background: radial-gradient(circle at top left, rgba(255,255,255,.48), transparent 28%), linear-gradient(90deg, rgba(0,0,0,.05), transparent 20%), repeating-linear-gradient(0deg, rgba(0,0,0,.012) 0 1px, transparent 1px 6px), #f0e5d1; color: var(--ink); border: 1px solid rgba(0,0,0,.18); padding: 40px; overflow: hidden; font-family: var(--font-serif); font-feature-settings: "kern"; -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
      .book-page::after { content: ""; position: absolute; inset: 0; pointer-events: none; background: linear-gradient(90deg, rgba(0,0,0,.09), transparent 12%, transparent 88%, rgba(0,0,0,.08)), radial-gradient(circle at 50% 30%, transparent 0%, rgba(0,0,0,.04) 100%); }
      .cover-page { background: radial-gradient(circle at 50% 22%, rgba(255,255,255,.16), transparent 23%), radial-gradient(circle at 50% 58%, rgba(255,255,255,.055), transparent 33%), linear-gradient(150deg, rgba(255,255,255,.08), transparent 32%), linear-gradient(180deg,#050506 0%,#000 100%); color: #fff; display: grid; place-items: center; text-align: center; padding: 42px; }
      .cover-page::after { background: linear-gradient(90deg, rgba(255,255,255,.08), transparent 18%, transparent 82%, rgba(255,255,255,.06)), radial-gradient(circle at 50% 60%, transparent 0%, rgba(0,0,0,.62) 78%); }
      .cover-art { position: absolute; inset: 0; overflow: hidden; z-index: 0; }
      .cover-art::before { content: ""; position: absolute; inset: 28px; border: 1px solid rgba(255,255,255,.2); box-shadow: inset 0 0 80px rgba(255,255,255,.035); }
      .cover-art::after { content: ""; position: absolute; left: 50%; top: 57%; width: 230px; height: 230px; transform: translate(-50%,-50%); border: 1px solid rgba(255,255,255,.16); border-radius: 999px; opacity: .5; }
      .moon { position: absolute; left: 50%; top: 24%; width: 112px; height: 112px; transform: translateX(-50%); border-radius: 999px; background: radial-gradient(circle at 34% 28%, #fff, rgba(255,255,255,.86) 31%, rgba(255,255,255,.12) 68%, transparent 70%); filter: blur(.2px) drop-shadow(0 0 44px rgba(255,255,255,.38)); opacity: .76; }
      .cat-silhouette { position: absolute; left: 50%; bottom: 142px; width: 86px; height: 64px; transform: translateX(-50%); border-radius: 48% 48% 36% 36%; background: rgba(0,0,0,.9); box-shadow: 0 0 0 1px rgba(255,255,255,.04), 0 18px 48px rgba(0,0,0,.62); }
      .cat-silhouette::before, .cat-silhouette::after { content: ""; position: absolute; top: -19px; width: 0; height: 0; border-left: 16px solid transparent; border-right: 16px solid transparent; border-bottom: 31px solid rgba(0,0,0,.9); }
      .cat-silhouette::before { left: 10px; transform: rotate(-18deg); }
      .cat-silhouette::after { right: 10px; transform: rotate(18deg); }
      .cover-content { position: relative; z-index: 1; display: grid; place-items: center; min-height: 100%; padding: 40px 18px; }
      .cover-author { color: rgba(255,255,255,.78); text-transform: uppercase; letter-spacing: .18em; font-family: var(--font-ui); font-size: 10px; font-weight: 700; margin: 0 0 auto; }
      .cover-page h2 { font-family: var(--font-serif); font-size: clamp(38px,6vw,56px); font-weight: 700; line-height: 1; letter-spacing: -.055em; margin: auto 0 22px; text-wrap: balance; text-shadow: 0 0 26px rgba(255,255,255,.12); }
      .cover-page small { color: rgba(255,255,255,.78); font-family: var(--font-ui); font-size: 10px; letter-spacing: .08em; line-height: 1.7; text-transform: uppercase; }
      .intro-page, .toc-page, .chapter-page { display: grid; align-content: center; font-family: var(--font-serif); }
      .intro-inner, .toc-inner, .chapter-inner { position: relative; z-index: 2; max-width: 305px; margin: 0 auto; }
      .intro-inner span, .toc-inner span, .chapter-inner span { display: block; color: rgba(0,0,0,.52); font-family: var(--font-ui); font-size: 9px; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; margin-bottom: 22px; }
      .intro-inner p, .chapter-inner p { font-size: 14.5px; line-height: 1.78; margin: 0 0 14px; }
      .toc-inner h2, .chapter-inner h2 { font-family: var(--font-serif); font-size: 36px; line-height: 1.02; letter-spacing: -.05em; margin: 0 0 22px; }
      .toc-list { display: grid; gap: 14px; margin-top: 28px; }
      .toc-item { display: grid; gap: 2px; padding-bottom: 12px; border-bottom: 1px solid rgba(0,0,0,.14); }
      .toc-item strong { font-size: 15px; line-height: 1.3; }
      .toc-item small { color: rgba(0,0,0,.52); font-family: var(--font-ui); font-size: 9px; letter-spacing: .12em; text-transform: uppercase; }
      .chapter-page { background: radial-gradient(circle at 50% 24%, rgba(255,255,255,.5), transparent 32%), linear-gradient(135deg, #f3ead9 0%, #e8d8bd 100%); text-align: center; }
      .chapter-inner h2 { font-size: 42px; }
      .decorated-page .botanical { position: absolute; pointer-events: none; z-index: 1; opacity: .13; filter: sepia(.25); }
      .botanical-top { top: 18px; left: 18px; width: 150px; height: 150px; }
      .botanical-bottom { right: 18px; bottom: 18px; width: 170px; height: 170px; transform: rotate(180deg); }
      .botanical::before, .botanical::after { content: ""; position: absolute; border-color: rgba(24,18,14,.74); }
      .botanical-rose .botanical::before { width: 82px; height: 82px; border: 1px solid rgba(24,18,14,.72); border-radius: 50% 46% 52% 44%; transform: rotate(-18deg); }
      .botanical-rose .botanical::after { left: 54px; top: 70px; width: 82px; height: 96px; border-left: 1px solid rgba(24,18,14,.72); border-bottom: 1px solid rgba(24,18,14,.36); border-radius: 0 0 0 70%; transform: rotate(-22deg); }
      .botanical-branch .botanical::before { left: 54px; top: 4px; width: 1px; height: 142px; background: rgba(24,18,14,.7); transform: rotate(28deg); }
      .botanical-branch .botanical::after { left: 42px; top: 22px; width: 92px; height: 114px; background: radial-gradient(ellipse at 22px 18px, transparent 0 10px, rgba(24,18,14,.62) 11px 12px, transparent 13px), radial-gradient(ellipse at 66px 44px, transparent 0 10px, rgba(24,18,14,.62) 11px 12px, transparent 13px), radial-gradient(ellipse at 28px 78px, transparent 0 10px, rgba(24,18,14,.62) 11px 12px, transparent 13px); transform: rotate(22deg); }
      .botanical-ginkgo .botanical::before { width: 118px; height: 82px; border-top: 1px solid rgba(24,18,14,.72); border-radius: 80% 80% 12% 12%; transform: rotate(-18deg); }
      .botanical-ginkgo .botanical::after { left: 56px; top: 72px; width: 1px; height: 82px; background: rgba(24,18,14,.62); transform: rotate(-8deg); }
      .botanical-wildflower .botanical::before { left: 70px; top: 6px; width: 1px; height: 142px; background: rgba(24,18,14,.62); transform: rotate(-16deg); }
      .botanical-wildflower .botanical::after { left: 26px; top: 18px; width: 108px; height: 108px; background: radial-gradient(circle at 30px 24px, transparent 0 8px, rgba(24,18,14,.68) 9px 10px, transparent 11px), radial-gradient(circle at 72px 48px, transparent 0 8px, rgba(24,18,14,.68) 9px 10px, transparent 11px), radial-gradient(circle at 48px 82px, transparent 0 8px, rgba(24,18,14,.68) 9px 10px, transparent 11px); }
      .poem-book-page { display: grid; align-content: start; }
      .book-page-number { position: absolute; right: 34px; bottom: 28px; color: rgba(0,0,0,.35); font-family: var(--font-ui); font-size: 10px; letter-spacing: .16em; z-index: 2; }
      .poem-book-page h2 { position: relative; z-index: 2; font-family: var(--font-serif); font-size: 24px; font-weight: 700; line-height: 1.16; letter-spacing: -.03em; margin: 10px 0 18px; }
      .book-date, .book-excerpt { display: none; }
      .book-poem-body { position: relative; z-index: 2; font-family: var(--font-serif); font-size: 12.5px; line-height: 1.68; }
      .book-poem-body p { margin: 0 0 11px; }
      .end-page { display: grid; place-items: center; text-align: center; font-family: var(--font-serif); font-size: 46px; font-weight: 700; }
      .end-page div { position: relative; z-index: 2; }
      .end-page small { display: block; color: rgba(0,0,0,.56); font-family: var(--font-ui); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; }
      .mobile-note { text-align: center; color: var(--muted); font-family: var(--font-ui); font-size: 14px; }
      @media (max-width:760px) { .book-section { padding-inline: 12px; } .book-wrap { min-height: 620px; overflow-x: hidden; } .book-page { padding: 32px; } .botanical-top, .botanical-bottom { opacity: .08; transform: scale(.82); } .poem-book-page h2 { font-size: 22px; } .book-poem-body { font-size: 12px; line-height: 1.62; } }
    </style>
  </body>
</html>
