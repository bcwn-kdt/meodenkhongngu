---
import "../../styles/global.css";
import FlipBook from "../../components/Flipbook.jsx";
import { getCollection } from "astro:content";
import { marked } from "marked";

const entries = await getCollection("poems");

const sorted = entries
  .filter((entry) => {
    return (
      entry.data.published &&
      entry.data.showInBook &&
      entry.data.collection === "Va Vào Lần Yêu Cuối"
    );
  })
  .sort((a, b) => {
    return (a.data.order || 999) - (b.data.order || 999);
  });

const poems = sorted.map((entry) => ({
  slug: entry.slug,
  title: entry.data.title,
  excerpt: entry.data.excerpt,
  html: marked.parse(entry.body || ""),
}));
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Va Vào Lần Yêu Cuối | Mèo Đen Không Ngủ</title>
  </head>

  <body>
    <div class="cursor-glow" aria-hidden="true"></div>

    <div class="site-shell">
      <header class="site-header glow-surface">
        <a class="logo glow-link" href="/">Mèo Đen Không Ngủ</a>

        <nav class="nav">
          <a class="glow-link" href="/tho">Thơ</a>
          <a class="glow-link" href="/tap-tho/va-vao-lan-yeu-cuoi">Va Vào Lần Yêu Cuối</a>
          <a class="glow-link" href="/ve-meo">Về Mèo</a>
        </nav>
      </header>
    </div>

    <FlipBook client:only="react" poems={poems} />

    <script is:inline src="/glow.js"></script>

    <style is:global>
      @import url("https://fonts.googleapis.com/css2?family=Courier+Prime:wght@400;700&display=swap");

      :root {
        --font-typewriter: "Courier Prime", "Courier New", "Liberation Mono", "DejaVu Sans Mono", monospace;
      }

      .book-section { position: relative; padding: 72px 20px 26px; overflow: hidden; perspective: 1800px; }
      .book-section::before { content: ""; position: absolute; inset: 6% 0 auto; height: 560px; pointer-events: none; background: radial-gradient(circle at 50% 0%, rgba(255,255,255,.16), transparent 34%), radial-gradient(circle at 22% 64%, rgba(94,213,255,.11), transparent 26%), radial-gradient(circle at 74% 58%, rgba(255,191,92,.12), transparent 28%); opacity: .72; filter: blur(16px); }
      .book-top { position: relative; z-index: 1; max-width: 820px; margin: 0 auto 52px; text-align: center; }
      .book-top h1 { font-family: var(--font-serif); font-size: clamp(48px,8vw,96px); font-weight: 700; line-height: 1; letter-spacing: -.06em; margin: 10px 0 22px; color: var(--text); text-wrap: balance; }
      .book-top p { color: var(--text-soft); font-family: var(--font-ui); font-size: clamp(16px,2vw,19px); line-height: 1.8; max-width: 720px; margin: 0 auto; }
      .book-wrap { position: relative; z-index: 1; min-height: 760px; display: grid; place-items: center; padding: 42px 0 70px; }
      .book-wrap::before { content: ""; position: absolute; left: 50%; bottom: 30px; width: min(860px, 84vw); height: 70px; transform: translateX(-50%); border-radius: 50%; background: radial-gradient(ellipse, rgba(0,0,0,.68), transparent 68%); filter: blur(12px); opacity: .82; }
      .flip-book { position: relative; filter: drop-shadow(0 46px 120px rgba(0,0,0,.86)); border-radius: 8px; }
      .flip-book::before { content: ""; position: absolute; inset: 14px auto 14px 50%; width: 44px; transform: translateX(-50%); z-index: 20; pointer-events: none; background: radial-gradient(ellipse at center, rgba(0,0,0,.22) 0%, rgba(0,0,0,.12) 24%, rgba(255,255,255,.08) 48%, rgba(0,0,0,.08) 72%, transparent 100%); filter: blur(12px); opacity: .34; }
      .book-page { position: relative; background: radial-gradient(circle at top left, rgba(255,255,255,.58), transparent 28%), linear-gradient(90deg, rgba(0,0,0,.085), transparent 18%, transparent 82%, rgba(0,0,0,.045)), repeating-linear-gradient(0deg, rgba(0,0,0,.014) 0 1px, transparent 1px 6px), #f1e6d2; color: #17120f; border: 1px solid rgba(0,0,0,.18); padding: 46px 48px 52px; overflow: hidden; font-family: var(--font-typewriter); font-feature-settings: "kern"; -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; box-shadow: inset 10px 0 22px rgba(0,0,0,.045), inset -9px 0 20px rgba(255,255,255,.2); }
      .book-page::before { content: ""; position: absolute; inset: 0; pointer-events: none; z-index: 0; background: linear-gradient(90deg, rgba(0,0,0,.09), transparent 10%, transparent 90%, rgba(0,0,0,.06)), radial-gradient(circle at 18% 12%, rgba(255,255,255,.46), transparent 22%), repeating-linear-gradient(90deg, rgba(80,54,25,.016) 0 1px, transparent 1px 5px); opacity: .72; }
      .book-page::after { content: ""; position: absolute; inset: 0; pointer-events: none; z-index: 1; background: linear-gradient(90deg, rgba(0,0,0,.08), transparent 14%, transparent 88%, rgba(0,0,0,.07)), radial-gradient(circle at 50% 30%, transparent 0%, rgba(0,0,0,.035) 100%); }
      .book-page > * { position: relative; z-index: 2; }
      .cover-page { background: radial-gradient(circle at 50% 22%, rgba(255,255,255,.18), transparent 23%), radial-gradient(circle at 50% 58%, rgba(94,213,255,.08), transparent 33%), linear-gradient(150deg, rgba(255,255,255,.09), transparent 32%), linear-gradient(180deg,#050506 0%,#000 100%); color: #fff; display: grid; place-items: center; text-align: center; padding: 42px; box-shadow: inset 0 0 0 1px rgba(255,255,255,.12), inset 20px 0 36px rgba(255,255,255,.04), inset -18px 0 38px rgba(0,0,0,.7); }
      .cover-page::after { background: linear-gradient(90deg, rgba(255,255,255,.1), transparent 18%, transparent 82%, rgba(255,255,255,.06)), radial-gradient(circle at 50% 60%, transparent 0%, rgba(0,0,0,.64) 78%); }
      .cover-art { position: absolute; inset: 0; overflow: hidden; z-index: 0; }
      .cover-art::before { content: ""; position: absolute; inset: 28px; border: 1px solid rgba(255,255,255,.2); box-shadow: inset 0 0 80px rgba(255,255,255,.035); }
      .cover-art::after { content: ""; position: absolute; left: 50%; top: 57%; width: 230px; height: 230px; transform: translate(-50%,-50%); border: 1px solid rgba(255,255,255,.16); border-radius: 999px; opacity: .5; }
      .moon { position: absolute; left: 50%; top: 24%; width: 112px; height: 112px; transform: translateX(-50%); border-radius: 999px; background: radial-gradient(circle at 34% 28%, #fff, rgba(255,255,255,.86) 31%, rgba(255,255,255,.12) 68%, transparent 70%); filter: blur(.2px) drop-shadow(0 0 44px rgba(255,255,255,.38)); opacity: .76; }
      .cat-silhouette { position: absolute; left: 50%; bottom: 142px; width: 86px; height: 64px; transform: translateX(-50%); border-radius: 48% 48% 36% 36%; background: rgba(0,0,0,.9); box-shadow: 0 0 0 1px rgba(255,255,255,.04), 0 18px 48px rgba(0,0,0,.62); }
      .cat-silhouette::before, .cat-silhouette::after { content: ""; position: absolute; top: -19px; width: 0; height: 0; border-left: 16px solid transparent; border-right: 16px solid transparent; border-bottom: 31px solid rgba(0,0,0,.9); }
      .cat-silhouette::before { left: 10px; transform: rotate(-18deg); }
      .cat-silhouette::after { right: 10px; transform: rotate(18deg); }
      .cover-content { position: relative; z-index: 2; display: grid; place-items: center; min-height: 100%; padding: 40px 18px; }
      .cover-author { color: rgba(255,255,255,.78); text-transform: uppercase; letter-spacing: .18em; font-family: var(--font-ui); font-size: 10px; font-weight: 700; margin: 0 0 auto; }
      .cover-page h2 { font-family: var(--font-serif); font-size: clamp(38px,6vw,56px); font-weight: 700; line-height: 1; letter-spacing: -.055em; margin: auto 0 22px; text-wrap: balance; text-shadow: 0 0 26px rgba(255,255,255,.12); }
      .cover-page small { color: rgba(255,255,255,.78); font-family: var(--font-ui); font-size: 10px; letter-spacing: .08em; line-height: 1.7; text-transform: uppercase; }
      .intro-page, .toc-page, .chapter-page { display: grid; align-content: center; font-family: var(--font-typewriter); }
      .intro-inner, .toc-inner, .chapter-inner { position: relative; z-index: 2; max-width: 305px; margin: 0 auto; }
      .intro-inner span, .toc-inner span, .chapter-inner span { display: block; color: rgba(0,0,0,.52); font-family: var(--font-typewriter); font-size: 9px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; margin-bottom: 22px; }
      .intro-inner p, .chapter-inner p { font-size: 13px; line-height: 1.78; margin: 0 0 14px; }
      .toc-inner h2, .chapter-inner h2 { font-family: var(--font-typewriter); font-size: 28px; line-height: 1.08; letter-spacing: -.04em; margin: 0 0 22px; }
      .toc-list { display: grid; gap: 14px; margin-top: 28px; }
      .toc-item { display: grid; gap: 2px; padding-bottom: 12px; border-bottom: 1px solid rgba(0,0,0,.14); }
      .toc-item strong { font-size: 13px; line-height: 1.35; color: #111; }
      .toc-item small { color: rgba(0,0,0,.52); font-family: var(--font-typewriter); font-size: 9px; letter-spacing: .12em; text-transform: uppercase; }
      .chapter-page { background: radial-gradient(circle at 50% 24%, rgba(255,255,255,.54), transparent 32%), linear-gradient(135deg, #f3ead9 0%, #e8d8bd 100%); text-align: center; }
      .chapter-inner h2 { font-size: 32px; }
      .decorated-page .botanical { position: absolute; pointer-events: none; z-index: 1; opacity: .11; filter: sepia(.25); }
      .botanical-top { top: 18px; left: 18px; width: 150px; height: 150px; }
      .botanical-bottom { right: 18px; bottom: 18px; width: 170px; height: 170px; transform: rotate(180deg); }
      .botanical::before, .botanical::after { content: ""; position: absolute; border-color: rgba(24,18,14,.74); }
      .botanical-rose .botanical::before { width: 82px; height: 82px; border: 1px solid rgba(24,18,14,.72); border-radius: 50% 46% 52% 44%; transform: rotate(-18deg); }
      .botanical-rose .botanical::after { left: 54px; top: 70px; width: 82px; height: 96px; border-left: 1px solid rgba(24,18,14,.72); border-bottom: 1px solid rgba(24,18,14,.36); border-radius: 0 0 0 70%; transform: rotate(-22deg); }
      .botanical-branch .botanical::before { left: 54px; top: 4px; width: 1px; height: 142px; background: rgba(24,18,14,.7); transform: rotate(28deg); }
      .botanical-branch .botanical::after { left: 42px; top: 22px; width: 92px; height: 114px; background: radial-gradient(ellipse at 22px 18px, transparent 0 10px, rgba(24,18,14,.62) 11px 12px, transparent 13px), radial-gradient(ellipse at 66px 44px, transparent 0 10px, rgba(24,18,14,.62) 11px 12px, transparent 13px), radial-gradient(ellipse at 28px 78px, transparent 0 10px, rgba(24,18,14,.62) 11px 12px, transparent 13px); transform: rotate(22deg); }
      .botanical-ginkgo .botanical::before { width: 118px; height: 82px; border-top: 1px solid rgba(24,18,14,.72); border-radius: 80% 80% 12% 12%; transform: rotate(-18deg); }
      .botanical-ginkgo .botanical::after { left: 56px; top: 72px; width: 1px; height: 82px; background: rgba(24,18,14,.62); transform: rotate(-8deg); }
      .botanical-wildflower .botanical::before { left: 70px; top: 6px; width: 1px; height: 142px; background: rgba(24,18,14,.64); transform: rotate(18deg); }
      .botanical-wildflower .botanical::after { left: 42px; top: 20px; width: 82px; height: 82px; background: radial-gradient(circle at 32px 24px, rgba(24,18,14,.62) 0 2px, transparent 3px), radial-gradient(circle at 50px 38px, rgba(24,18,14,.62) 0 2px, transparent 3px), radial-gradient(circle at 20px 58px, rgba(24,18,14,.62) 0 2px, transparent 3px); }
      .book-page-number { position: absolute; right: 34px; bottom: 28px; color: rgba(0,0,0,.35); font-family: var(--font-typewriter); font-size: 9px; letter-spacing: .16em; z-index: 2; }
      .poem-book-page h2 { position: relative; z-index: 2; font-family: var(--font-typewriter); color: #0f0d0a; font-size: 18px; font-weight: 700; line-height: 1.28; letter-spacing: -.015em; margin: 4px 0 18px; max-width: 92%; }
      .book-date, .book-excerpt { display: none; }
      .book-poem-body { position: relative; z-index: 2; font-family: var(--font-typewriter); color: #17120f; font-size: 11px; line-height: 1.72; letter-spacing: -.015em; max-width: 94%; }
      .book-poem-body p { margin: 0 0 10px; }
      .book-poem-body em { font-style: italic; }
      .end-page { display: grid; place-items: center; text-align: center; font-family: var(--font-typewriter); font-size: 34px; font-weight: 700; color: #111; }
      .end-page div { position: relative; z-index: 2; }
      .end-page small { display: block; color: rgba(0,0,0,.56); font-family: var(--font-typewriter); font-size: 10px; letter-spacing: .1em; text-transform: uppercase; }
      .mobile-note { text-align: center; color: var(--muted); font-family: var(--font-ui); font-size: 14px; }
      @media (max-width:760px) { .book-section { padding: 48px 0 20px; overflow-x: hidden; } .book-top { width: min(100% - 28px, 720px); margin-bottom: 30px; } .book-top h1 { font-size: clamp(38px, 12vw, 58px); line-height: 1.02; } .book-top p { font-size: 14.5px; line-height: 1.7; } .book-wrap { min-height: 560px; overflow-x: hidden; padding: 18px 0 34px; transform: scale(.94); transform-origin: top center; } .book-wrap::before { width: 92vw; height: 42px; bottom: 18px; opacity: .54; } .flip-book { filter: drop-shadow(0 26px 70px rgba(0,0,0,.74)); } .flip-book::before { opacity: .12; width: 30px; filter: blur(14px); } .book-page { padding: 32px 30px 36px; } .botanical-top, .botanical-bottom { opacity: .07; transform: scale(.78); } .poem-book-page h2 { font-size: 16px; line-height: 1.28; margin-bottom: 14px; } .book-poem-body { font-size: 10.4px; line-height: 1.62; } .book-page-number { right: 24px; bottom: 22px; } .mobile-note { width: min(100% - 28px, 560px); margin: 0 auto; font-size: 12.5px; line-height: 1.6; } }
      @media (max-width:420px) { .book-wrap { transform: scale(.88); min-height: 520px; } .book-page { padding: 30px 26px 34px; } .book-poem-body { font-size: 10px; line-height: 1.58; } .poem-book-page h2 { font-size: 15px; } }
    </style>
  </body>
</html>
