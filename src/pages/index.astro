---
import "../styles/global.css";
import { getCollection } from "astro:content";

const poems = await getCollection("poems");
const published = poems
  .filter((poem) => poem.data.published)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latest = published.slice(0, 6);
const bookCount = published.filter((poem) => poem.data.showInBook).length;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mèo Đen Không Ngủ</title>
    <meta
      name="description"
      content="Mèo Đen Không Ngủ là kho lưu trữ thơ cá nhân, nơi cất lại những đêm dài, những lần yêu và những phiên bản cũ đã từng rất buồn."
    />
  </head>

  <body>
    <div class="cursor-glow" aria-hidden="true"></div>

    <div class="site-shell">
      <header class="site-header glow-surface">
        <a class="logo glow-link" href="/">Mèo Đen Không Ngủ</a>

        <nav class="nav">
          <a class="glow-link" href="/tho">Thơ</a>
          <a class="glow-link" href="/tap-tho/va-vao-lan-yeu-cuoi">Va Vào Lần Yêu Cuối</a>
          <a class="glow-link" href="/ve-meo">Về Mèo</a>
        </nav>
      </header>

      <main>
        <section class="home-hero glow-surface">
          <div class="home-hero-copy">
            <p class="eyebrow">tuyển tập thơ cá nhân</p>
            <h1>Mèo Đen Không Ngủ</h1>
            <p class="intro">
              Một căn phòng tối để cất lại những bài thơ, những mùa yêu,
              những lần rời đi, và những phiên bản cũ đã từng rất buồn.
            </p>

            <div class="button-row">
              <a class="button glow-button" href="/tho">Vào kho thơ</a>
              <a class="button secondary glow-button" href="/tap-tho/va-vao-lan-yeu-cuoi">
                Đọc sách lật
              </a>
            </div>
          </div>

          <aside class="home-book-card glow-card" aria-label="Tập thơ nổi bật">
            <p class="eyebrow">tập thơ nổi bật</p>
            <h2>Va Vào<br />Lần Yêu Cuối</h2>
            <p>
              Một tuyển tập thơ về những lần yêu, những đêm dài và cách một người học đặt nỗi buồn xuống.
            </p>
            <a class="text-link" href="/tap-tho/va-vao-lan-yeu-cuoi">Mở tập thơ →</a>
          </aside>
        </section>

        <section class="home-panels" aria-label="Lối vào nhanh">
          <a class="home-panel glow-card" href="/tho">
            <span>{published.length}</span>
            <h2>Kho thơ</h2>
            <p>Đọc toàn bộ bài thơ theo dạng mục lục gọn, có tìm kiếm và bộ lọc.</p>
          </a>

          <a class="home-panel glow-card" href="/tap-tho/va-vao-lan-yeu-cuoi">
            <span>{bookCount}</span>
            <h2>Sách lật</h2>
            <p>Một ấn bản điện tử với hiệu ứng lật trang và bố cục như bản thảo.</p>
          </a>

          <a class="home-panel glow-card" href="/ve-meo">
            <span>∞</span>
            <h2>Về Mèo</h2>
            <p>Một lời tự bạch nhỏ về nơi cất giữ những bài thơ này.</p>
          </a>
        </section>

        <section class="archive home-latest glow-surface">
          <div class="section-heading-row">
            <div>
              <p class="eyebrow">mục lục mới</p>
              <h2 class="section-title">Những bài gần đây</h2>
            </div>
            <a class="text-link" href="/tho">Xem tất cả →</a>
          </div>

          <div class="poem-list poem-list-minimal">
            {
              latest.map((poem) => (
                <a class="poem-item glow-card" href={`/tho/${poem.id.replace(/\.md$/, "")}`}>
                  <div>
                    <h2>{poem.data.title}</h2>
                    <div class="poem-tags">
                      {poem.data.collection && <small>{poem.data.collection}</small>}
                      {poem.data.mood && <small>{poem.data.mood}</small>}
                    </div>
                  </div>
                </a>
              ))
            }
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <p>© Mèo Đen Không Ngủ</p>
      </footer>
    </div>

    <script is:inline src="/glow.js"></script>
  </body>
</html>
