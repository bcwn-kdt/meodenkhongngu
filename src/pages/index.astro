---
import "../styles/global.css";
import { getCollection } from "astro:content";

const poems = await getCollection("poems");
const latest = poems
  .filter((poem) => poem.data.published)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mèo Đen Không Ngủ</title>
  </head>

  <body>
    <div class="cursor-glow" aria-hidden="true"></div>

    <div class="site-shell">
      <header class="site-header glow-surface">
        <a class="logo glow-link" href="/">Mèo Đen Không Ngủ</a>

        <nav class="nav">
          <a class="glow-link" href="/tho">Thơ</a>
          <a class="glow-link" href="/tap-tho/va-vao-lan-yeu-cuoi">Va Vào Lần Yêu Cuối</a>
          <a class="glow-link" href="/ve-meo">Về Mèo</a>
        </nav>
      </header>

      <main>
        <section class="hero glow-surface">
          <p class="eyebrow">kho lưu trữ thơ cá nhân</p>

          <h1>Mèo Đen Không Ngủ</h1>

          <p class="intro">
            Một căn phòng tối để cất lại thơ, hình ảnh, những lần yêu,
            những lần rời đi, và những phiên bản cũ đã từng rất buồn.
          </p>

          <div class="button-row">
            <a class="button glow-button" href="/tho">Đọc thơ</a>
            <a class="button secondary glow-button" href="/tap-tho/va-vao-lan-yeu-cuoi">
              Mở tập thơ
            </a>
          </div>
        </section>

        <section class="archive glow-surface">
          <p class="eyebrow">những bài thơ mới</p>
          <h2 class="section-title">Thơ mới nhất</h2>

          <div class="poem-list">
            {
              latest.map((poem) => (
                <a class="poem-item glow-card" href={`/tho/${poem.id.replace(/\.md$/, "")}`}>
                  <span>{poem.data.date.toLocaleDateString("vi-VN")}</span>
                  <h2>{poem.data.title}</h2>
                  {poem.data.excerpt && <p>{poem.data.excerpt}</p>}
                </a>
              ))
            }
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <p>© Mèo Đen Không Ngủ</p>
      </footer>
    </div>

    <script is:inline>
      const cursorGlow = document.querySelector(".cursor-glow");
      const interactiveElements = document.querySelectorAll(".glow-surface, .glow-card, .glow-button, .glow-link");

      window.addEventListener("pointermove", (event) => {
        document.documentElement.style.setProperty("--cursor-x", `${event.clientX}px`);
        document.documentElement.style.setProperty("--cursor-y", `${event.clientY}px`);

        if (cursorGlow) {
          cursorGlow.style.opacity = "1";
          cursorGlow.style.transform = `translate3d(${event.clientX}px, ${event.clientY}px, 0)`;
        }

        interactiveElements.forEach((element) => {
          const rect = element.getBoundingClientRect();
          element.style.setProperty("--mouse-x", `${event.clientX - rect.left}px`);
          element.style.setProperty("--mouse-y", `${event.clientY - rect.top}px`);
        });
      });

      window.addEventListener("pointerleave", () => {
        if (cursorGlow) cursorGlow.style.opacity = "0";
      });
    </script>
  </body>
</html>

<style>
  .section-title {
    font-family: Georgia, serif;
    font-size: 46px;
    line-height: 1;
    margin: 10px 0 0;
  }
</style>
