---
import "../styles/global.css";
import { getCollection } from "astro:content";

const poems = await getCollection("poems");
const latest = poems
  .filter((poem) => poem.data.published)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mèo Đen Không Ngủ</title>
  </head>

  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="logo" href="/">Mèo Đen Không Ngủ</a>

        <nav class="nav">
          <a href="/tho">Thơ</a>
          <a href="/tap-tho/va-vao-lan-yeu-cuoi">Va Vào Lần Yêu Cuối</a>
          <a href="/ve-meo">Về Mèo</a>
          <a href="/admin">Admin</a>
        </nav>
      </header>

      <main>
        <section class="hero">
          <p class="eyebrow">personal poetry archive</p>

          <h1>Mèo Đen Không Ngủ</h1>

          <p class="intro">
            Một căn phòng tối để cất lại thơ, hình ảnh, những lần yêu,
            những lần rời đi, và những phiên bản cũ đã từng rất buồn.
          </p>

          <div class="button-row">
            <a class="button" href="/tho">Đọc thơ</a>
            <a class="button secondary" href="/tap-tho/va-vao-lan-yeu-cuoi">
              Mở tập thơ
            </a>
          </div>
        </section>

        <section class="archive">
          <p class="eyebrow">latest poems</p>
          <h2 class="section-title">Thơ mới nhất</h2>

          <div class="poem-list">
            {
              latest.map((poem) => (
                <a class="poem-item" href={`/tho/${poem.id.replace(/\.md$/, "")}`}>
                  <span>{poem.data.date.toLocaleDateString("vi-VN")}</span>
                  <h2>{poem.data.title}</h2>
                  {poem.data.excerpt && <p>{poem.data.excerpt}</p>}
                </a>
              ))
            }
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <p>© Mèo Đen Không Ngủ </p>
      </footer>
    </div>
  </body>
</html>

<style>
  .section-title {
    font-family: Georgia, serif;
    font-size: 46px;
    line-height: 1;
    margin: 10px 0 0;
  }
</style>